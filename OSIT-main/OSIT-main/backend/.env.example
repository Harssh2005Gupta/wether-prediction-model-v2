# OSIT AI Farming Backend — Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (required for Crop Doctor and LLM recommendations)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Gemini Model to use (optional, defaults to gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# OpenWeatherMap API Key (optional — falls back to Open-Meteo free API if missing)
OPENWEATHER_API_KEY=your_openweather_api_key_here
